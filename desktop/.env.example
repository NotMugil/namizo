# TVDB
# Get your API key from thetvdb.com → Account → API Keys
# https://thetvdb.com/api-information
TVDB_API_KEY="your_tvdb_api_key_here"

# Drizzle
# Replace with your DB credentials
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=require"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="replace_with_a_64_char_hex_secret"

# App origin
ORIGIN="http://localhost:1421"

# AniList OAuth
# Create your app at: https://anilist.co/settings/developer
# Redirect URI must match exactly what you set in the AniList developer console
ANILIST_CLIENT_ID="your_anilist_client_id"
ANILIST_CLIENT_SECRET="your_anilist_client_secret"
ANILIST_REDIRECT_URI="http://localhost:1421/api/anilist/callback"
